{% sw_extends '@Storefront/storefront/page/account/_page.html.twig' %}

{% block page_account_main_content %}
    <div class="account-merge-error">
        <div class="account-welcome">
            <h1>{{ "laenen.merge.error.title"|trans }}</h1>
        </div>

        <div class="alert alert-danger" role="alert">
            {{ page.errorMessage }}
        </div>

        <a href="{{ path('frontend.account.home.page') }}" class="btn btn-secondary">
            {{ "laenen.merge.error.backToAccount"|trans }}
        </a>
    </div>
{% endblock %}
