{% sw_extends '@Storefront/storefront/page/account/_page.html.twig' %}

{% block page_account_main_content %}
    <div class="account-merge-success">
        <div class="account-welcome">
            <h1>{{ "laenen.merge.success.title"|trans }}</h1>
        </div>

        <div class="alert alert-success" role="alert">
            {{ "laenen.merge.success.message"|trans({'%count%': page.result.movedOrderCount}) }}
        </div>

        <a href="{{ path('frontend.account.order.page') }}" class="btn btn-primary">
            {{ "laenen.merge.success.viewOrders"|trans }}
        </a>
    </div>
{% endblock %}
