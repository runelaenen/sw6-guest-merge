{% sw_extends '@Storefront/storefront/page/account/_page.html.twig' %}

{% block page_account_main_content %}
    <div class="account-merge-guest-orders">
        <div class="account-welcome">
            <h1>{{ "laenen.merge.title"|trans }}</h1>
            <p>{{ "laenen.merge.intro"|trans }}</p>
        </div>

        {% set candidates = page.candidates %}
        {% set latest = page.latestRequest %}

        {% if candidates is empty or candidates.orderCount == 0 %}
            <div class="alert alert-info" role="alert">
                {{ "laenen.merge.empty"|trans }}
            </div>
        {% else %}
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        {{ "laenen.merge.summary.title"|trans }}
                    </h5>
                    <ul>
                        <li>
                            {{ "laenen.merge.summary.orderCount"|trans({'%count%': candidates.orderCount}) }}
                        </li>
                        <li>
                            {{ "laenen.merge.summary.totalAmount"|trans }}:
                            <strong>{{ candidates.totalAmount|currency }}</strong>
                        </li>
                        {% if candidates.oldestOrderDate %}
                            <li>
                                {{ "laenen.merge.summary.oldest"|trans }}:
                                {{ candidates.oldestOrderDate|format_date('medium', locale=app.request.locale) }}
                            </li>
                        {% endif %}
                        {% if candidates.newestOrderDate %}
                            <li>
                                {{ "laenen.merge.summary.newest"|trans }}:
                                {{ candidates.newestOrderDate|format_date('medium', locale=app.request.locale) }}
                            </li>
                        {% endif %}
                    </ul>

                    {% if latest and latest.status == 'pending' %}
                        <div class="alert alert-warning" role="alert">
                            {{ "laenen.merge.pending.exists"|trans({'%expiresAt%': latest.expiresAt}) }}
                        </div>
                    {% else %}
                        {% if page.allowSelfService %}
                            <form action="{{ path('frontend.account.laenen.merge.initiate') }}"
                                  method="post"
                                  data-form-csrf-handler="true">
                                <button type="submit" class="btn btn-primary">
                                    {{ "laenen.merge.cta.send"|trans }}
                                </button>
                            </form>
                            <p class="text-muted small mt-3">
                                {{ "laenen.merge.cta.disclaimer"|trans }}
                            </p>
                        {% else %}
                            <div class="alert alert-secondary" role="alert">
                                {{ "laenen.merge.contactCsr"|trans }}
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
